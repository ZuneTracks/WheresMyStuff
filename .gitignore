# Git ignore file for Windows 10 Mobile app

## Ignore Visual Studio temporary files, build results, and files generated by popular Visual Studio add-ons.

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio cache/options
.vs/

# Visual Studio Code
.vscode/
*.code-workspace

# Rider
.idea/
*.sln.iml

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# NuGet Packages
*.nupkg
*.snupkg
.nuget/

# Temporary NuGet files
.nuget/packages/
.nuget/project.json

# Windows Mobile packages
*.xap
*.appx
*.appxbundle
*.appxupload

# Certificatates
*.pfx
*.cer

# ASP.NET Core
wwwroot/

# Rider files
.rider/

# OS specific
.DS_Store
Thumbs.db

# Test Results
TestResults/

# Resharper/Rider
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# Local environment variables
.env
.env.local
