<Application
    x:Class="WheresMyStuff.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WheresMyStuff"
    RequestedTheme="Light">

    <Application.Resources>
        <!-- Application-level resources -->
        
        <!-- Colors -->
        <Color x:Key="PrimaryColor">#FF0078D4</Color>
        <Color x:Key="AccentColor">#FFC239B3</Color>
        <Color x:Key="SuccessColor">#FF107C10</Color>
        <Color x:Key="ErrorColor">#FFE81123</Color>
        <Color x:Key="WarningColor">#FFFFB900</Color>
        
        <!-- Brushes -->
        <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
        <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}"/>
        <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
        
        <!-- Font Sizes -->
        <x:Double x:Key="HeaderFontSize">32</x:Double>
        <x:Double x:Key="SubHeaderFontSize">24</x:Double>
        <x:Double x:Key="NormalFontSize">14</x:Double>
        <x:Double x:Key="SmallFontSize">12</x:Double>
        
    </Application.Resources>

</Application>
