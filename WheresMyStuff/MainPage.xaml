<Page
    x:Class="WheresMyStuff.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WheresMyStuff"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="AdaptiveVisualStateGroup">
                <VisualState x:Name="VisualStateNarrow">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0"/>
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="InputStackPanel.Orientation" Value="Vertical"/>
                        <Setter Target="PackageListView.Margin" Value="0,20,0,0"/>
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="VisualStateNormal">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="720"/>
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="InputStackPanel.Orientation" Value="Horizontal"/>
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Padding="20,10,20,10" Background="{StaticResource PrimaryBrush}">
            <TextBlock 
                Text="📦 Where's My Stuff" 
                FontSize="32" 
                FontWeight="Bold" 
                Foreground="White" 
                Margin="0,0,0,5"/>
            <TextBlock 
                Text="Track your packages with real-time updates" 
                FontSize="14" 
                Foreground="White" 
                Opacity="0.8"/>
        </StackPanel>

        <!-- Input Section -->
        <StackPanel Grid.Row="1" Padding="20" Spacing="10">
            <TextBlock 
                Text="Add New Package" 
                FontSize="20" 
                FontWeight="SemiBold" 
                Margin="0,0,0,10"/>
            
            <StackPanel x:Name="InputStackPanel" Spacing="10" Orientation="Vertical">
                <TextBox 
                    x:Name="TrackingNumberTextBox" 
                    PlaceholderText="Tracking Number" 
                    Width="200"/>
                
                <ComboBox 
                    x:Name="CarrierComboBox" 
                    PlaceholderText="Select Carrier" 
                    Width="200"
                    ItemsSource="{Binding Carriers}">
                    <ComboBoxItem>fedex</ComboBoxItem>
                    <ComboBoxItem>ups</ComboBoxItem>
                    <ComboBoxItem>usps</ComboBoxItem>
                    <ComboBoxItem>dhl</ComboBoxItem>
                </ComboBox>
                
                <TextBox 
                    x:Name="SenderTextBox" 
                    PlaceholderText="Sender (Optional)" 
                    Width="200"/>
                
                <TextBox 
                    x:Name="RecipientTextBox" 
                    PlaceholderText="Recipient (Optional)" 
                    Width="200"/>
                
                <TextBox 
                    x:Name="NotesTextBox" 
                    PlaceholderText="Notes (Optional)" 
                    Width="200"
                    Height="60"
                    TextWrapping="Wrap"
                    AcceptsReturn="True"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button 
                    Content="Add Package" 
                    Click="AddPackageButton_Click"
                    Padding="20,10"
                    Background="{StaticResource SuccessBrush}"/>
                
                <Button 
                    Content="Refresh All" 
                    Click="RefreshButton_Click"
                    Padding="20,10"
                    Background="{StaticResource PrimaryBrush}"/>
            </StackPanel>
        </StackPanel>

        <!-- Status Message -->
        <TextBlock 
            Grid.Row="2"
            x:Name="StatusTextBlock"
            Text="{Binding StatusMessage}"
            Padding="20,5,20,5"
            FontSize="12"
            Foreground="{StaticResource PrimaryBrush}"
            TextWrapping="Wrap"/>

        <!-- Package List -->
        <ListView 
            x:Name="PackageListView"
            Grid.Row="2"
            ItemsSource="{Binding Packages}"
            Padding="20"
            SelectionMode="Single"
            IsItemClickEnabled="True"
            ItemClick="PackageListView_ItemClick">
            
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="10" Background="{ThemeResource SystemListLowColor}" CornerRadius="5" Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="5">
                            <TextBlock 
                                Text="{Binding TrackingNumber}" 
                                FontSize="16" 
                                FontWeight="Bold"/>
                            
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock 
                                    Text="{Binding CarrierName}" 
                                    FontSize="12" 
                                    Foreground="{StaticResource PrimaryBrush}"/>
                                <TextBlock 
                                    Text="{Binding GetStatusDescription}" 
                                    FontSize="12" 
                                    Foreground="{StaticResource SuccessBrush}"/>
                            </StackPanel>
                            
                            <TextBlock 
                                Text="{Binding CurrentLocation}" 
                                FontSize="12" 
                                Opacity="0.8"
                                TextWrapping="Wrap"/>
                            
                            <TextBlock 
                                Text="{Binding LastUpdated}" 
                                FontSize="11" 
                                Foreground="{ThemeResource SystemListMediumColor}"/>
                        </StackPanel>

                        <Button 
                            Grid.Column="1"
                            Content="✕" 
                            Click="DeleteButton_Click"
                            Padding="15,10"
                            Background="{StaticResource ErrorBrush}"
                            Foreground="White"
                            VerticalAlignment="Top"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Loading Indicator -->
        <ProgressRing 
            Grid.Row="2"
            x:Name="LoadingProgressRing"
            IsActive="{Binding IsLoading}"
            Width="60"
            Height="60"
            Foreground="{StaticResource PrimaryBrush}"/>

        <!-- Footer -->
        <StackPanel 
            Grid.Row="3" 
            Padding="20,10,20,10" 
            Background="{ThemeResource SystemListLowColor}">
            <TextBlock 
                Text="Tap a package to view details or swipe to remove" 
                FontSize="12" 
                Foreground="{ThemeResource SystemListMediumColor}"/>
        </StackPanel>
    </Grid>
</Page>
